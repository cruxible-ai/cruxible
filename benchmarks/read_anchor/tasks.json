  "tasks": [
    {
      "id": "op-1-deps-of-runebench-pilot",
      "instance": "operation",
      "question": "What work items does wi-runebench-pilot depend on?",
      "calls": [
        {
          "purpose": "Naive first look: fetch the entity, hoping deps are in properties (miss - deps are edges)",
          "args": ["entity", "get", "--type", "WorkItem", "--id", "wi-runebench-pilot", "--json"]
        },
        {
          "purpose": "Neighborhood inspect to find dependency edges",
          "args": ["entity", "inspect", "--type", "WorkItem", "--id", "wi-runebench-pilot", "--json"]
        }
      ],
      "expect": {
        "kind": "neighbor_edge",
        "relationship_type": "work_item_depends_on_work_item",
        "direction": "outgoing",
        "entity_id": "wi-bounded-neighborhood-inspect"
      },
      "ergonomic": {
        "instance": "operation_local",
        "calls": [
          {
            "purpose": "One bounded neighborhood read: depth-1, WorkItem neighbors only, compact cards. --state all is REQUIRED here: this instance's dependency edges are pending direct adds, and the expanded read defaults to live (the legacy single-hop inspect showed them regardless).",
            "args": ["entity", "inspect", "--type", "WorkItem", "--id", "wi-runebench-pilot", "--depth", "1", "--target-type", "WorkItem", "--state", "all", "--profile", "compact", "--json"]
          }
        ],
        "expect": {
          "kind": "graph_edge",
          "relationship_type": "work_item_depends_on_work_item",
          "entity_id": "wi-bounded-neighborhood-inspect"
        }
      },
      "ergonomic_v2": {
        "instance": "operation_local",
        "calls": [
          {
            "purpose": "Same bounded neighborhood read, NO --state flag: expanded inspect now defaults to state=all (with per-edge/entity state markers), so the pending dependency edges appear in the default flow instead of silently vanishing.",
            "args": ["entity", "inspect", "--type", "WorkItem", "--id", "wi-runebench-pilot", "--depth", "1", "--target-type", "WorkItem", "--profile", "compact", "--json"]
          }
        ],
        "expect": {
          "kind": "graph_edge",
          "relationship_type": "work_item_depends_on_work_item",
          "entity_id": "wi-bounded-neighborhood-inspect"
        }
      }
    },
    {
      "id": "op-2-milestone-of-agent-local-working-set",
      "instance": "operation",
      "question": "Which milestone is wi-agent-local-working-set in?",
      "calls": [
        {
          "purpose": "Cold discovery: what queries exist?",
          "args": ["query", "list", "--json"]
        },
        {
          "purpose": "Learn required params for the context query",
          "args": ["query", "describe", "--query", "work_item_context", "--json"]
        },
        {
          "purpose": "Run the context query for the work item",
          "args": ["query", "run", "work_item_context", "--param", "work_item_id=wi-agent-local-working-set", "--json"]
        }
      ],
      "expect": {
        "kind": "json_contains_string",
        "value": "ms-dx-friction"
      },
      "ergonomic": {
        "instance": "operation_local",
        "calls": [
          {
            "purpose": "Cold orientation: stats lists entity types AND relationship vocabulary (work_item_in_milestone) in ~3 KB",
            "args": ["stats", "--json"]
          },
          {
            "purpose": "One bounded neighborhood read filtered to the milestone edge, compact cards. Replaces query list + describe + a 276 KB context query for a one-edge answer.",
            "args": ["entity", "inspect", "--type", "WorkItem", "--id", "wi-agent-local-working-set", "--depth", "1", "--relationship", "work_item_in_milestone", "--profile", "compact", "--json"]
          }
        ]
      }
    },
    {
      "id": "op-3-owner-of-read-output-profiles",
      "instance": "operation",
      "question": "Which Actor owns wi-read-output-profiles?",
      "calls": [
