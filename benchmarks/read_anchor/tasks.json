          "purpose": "Neighborhood inspect to find the ownership edge",
          "args": ["entity", "inspect", "--type", "WorkItem", "--id", "wi-read-output-profiles", "--json"]
        }
      ],
      "expect": {
        "kind": "neighbor_edge",
        "relationship_type": "work_item_owned_by_actor",
        "entity_id": "fable-impl"
      },
      "ergonomic": {
        "instance": "operation_local",
        "calls": [
          {
            "purpose": "Same single-hop inspect, compact profile (no extra knowledge needed; the win is pure serialization)",
            "args": ["entity", "inspect", "--type", "WorkItem", "--id", "wi-read-output-profiles", "--profile", "compact", "--json"]
          }
        ]
      }
    },
    {
      "id": "op-4-workitem-counts-and-recent",
      "instance": "operation",
      "question": "How many WorkItems exist, and what was touched most recently?",
      "calls": [
        {
          "purpose": "Get graph-wide counts",
          "args": ["stats", "--json"]
        },
        {
          "purpose": "Sample the WorkItem listing (also returns total)",
          "args": ["list", "entities", "--type", "WorkItem", "--limit", "3", "--json"]
        },
        {
          "purpose": "Most recent activity via receipts",
          "args": ["list", "receipts", "--limit", "3", "--json"]
        }
      ],
      "expect": {
        "kind": "stats_list_match",
        "entity_type": "WorkItem",
        "expected_total": 162
      },
      "ergonomic": {
        "instance": "operation_local",
        "calls": [
          {
            "purpose": "Get graph-wide counts",
            "args": ["stats", "--json"]
          },
          {
            "purpose": "Sample the WorkItem listing with compact cards (also returns total)",
            "args": ["list", "entities", "--type", "WorkItem", "--limit", "3", "--profile", "compact", "--json"]
          },
          {
            "purpose": "Most recent activity via receipts (no profile flag on receipts; already bounded)",
            "args": ["list", "receipts", "--limit", "3", "--json"]
          }
        ],
        "expect": {
          "kind": "stats_list_match",
          "entity_type": "WorkItem",
          "expected_total": 164,
          "comment": "164 = the live total at post-track capture time; the baseline task pins 162 from the pre-track capture (instance drift, not a code change)."
        }
      }
    },
    {
